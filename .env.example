ELASTICSEARCH_VERSION=9.4.3
ELASTICSEARCH_URL=http://127.0.0.1:9200
ELASTICSEARCH_HEAP=2g
ELSER_INFERENCE_ID=mtrag-elser

OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:4b-q4_K_M
OLLAMA_NUM_CTX=8192
OLLAMA_NUM_PREDICT=512
OLLAMA_SEED=42
OLLAMA_KEEP_ALIVE=10m
OLLAMA_TIMEOUT=600

MTRAG_BENCHMARK_ROOT=../mt-rag-benchmark
BGE_MODEL_PATH=~/.cache/mtrag/models/bge-m3
RERANKER_MODEL_PATH=~/.cache/mtrag/models/bge-reranker-v2-m3
BGE_BATCH_SIZE=32
BGE_MAX_LENGTH=512
RERANKER_BATCH_SIZE=8
RERANKER_MAX_LENGTH=512
