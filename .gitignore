.env
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/

# Elasticsearch repositories contain large runtime artifacts.
artifacts/elasticsearch/archives/**
artifacts/elasticsearch/snapshots/**
!artifacts/elasticsearch/snapshots/**/
!artifacts/elasticsearch/snapshots/**/.gitkeep

# Experiment campaigns are content-addressed runtime data. Existing tracked
# historical files stay tracked, but new revisions must not become Git blobs.
runs/**
